#!/usr/bin/env bash
# stt-download — pre-download speech models from the speaches server.
# Usage:
#   stt-download          download all aliases
#   stt-download hu en    download specific language codes
set -uo pipefail

CONFIG_FILE="${STT_CONFIG:-$HOME/.config/stt/config.json}"
ALIASES_FILE="${STT_ALIASES:-$HOME/.config/stt/aliases.json}"
cfg() { [ -f "$CONFIG_FILE" ] && jq -r "$1 // empty" "$CONFIG_FILE" 2>/dev/null || true; }

url="$(cfg '.url')"; url="${url:-http://localhost:8000/v1}"

if [ $# -gt 0 ]; then
  keys=("$@")
else
  mapfile -t keys < <(jq -r 'keys[]' "$ALIASES_FILE" 2>/dev/null || true)
fi

downloaded="$(curl -s "$url/models" 2>/dev/null | jq -r '.data[].id' 2>/dev/null || true)"

for key in "${keys[@]}"; do
  model="$(jq -r ".\"$key\".model // empty" "$ALIASES_FILE")"
  name="$(jq -r ".\"$key\".name // empty" "$ALIASES_FILE")"

  if [ -z "$model" ]; then
    printf "  \e[31mERR\e[0m  %-6s unknown alias\n" "$key"
    continue
  fi

  if echo "$downloaded" | grep -qxF "$model"; then
    printf "  \e[32mOK\e[0m   %-6s %-12s already downloaded\n" "$key" "$name"
    continue
  fi

  printf "  \e[33m…\e[0m    %-6s %-12s downloading %s\n" "$key" "$name" "$model"
  code="$(curl -s -o /dev/null -w '%{http_code}' -X POST "$url/models/$key" 2>/dev/null)"
  if [ "$code" = "200" ]; then
    printf "  \e[32mOK\e[0m   %-6s %-12s done\n" "$key" "$name"
  else
    printf "  \e[31mFAIL\e[0m %-6s %-12s HTTP %s\n" "$key" "$name" "$code"
  fi
done
