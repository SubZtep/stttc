#!/usr/bin/env bash
# stt — record mic until SIGINT/SIGTERM, transcribe via a local speaches
# server, print transcript to stdout (exit 0) or an error to stderr (exit 1).
#
# Env (optional, override config file values):
#   STT_URL       base API URL
#   STT_MODEL     model for transcription
#   STT_LANGUAGE  e.g. "hu"
#   STT_DEVICE    ffmpeg/pulse input device
#   STT_DEBUG     set to 1 to print http status and raw response to stderr
set -uo pipefail

_CFG="$HOME/.config/stt/config.json"
_ALIASES="$HOME/.config/stt/aliases.json"
_cfg() { [ -f "$_CFG" ] && jq -r "$1 // empty" "$_CFG" 2>/dev/null || true; }
_alias() { [ -f "$_ALIASES" ] && jq -r "$1 // empty" "$_ALIASES" 2>/dev/null || true; }

# ---- single-instance: kill any previous stt and orphaned ffmpeg ----
_PID_FILE="/tmp/stt.pid"
if [ -f "$_PID_FILE" ]; then
  _old_pid="$(cat "$_PID_FILE" 2>/dev/null || true)"
  if [ -n "$_old_pid" ] && kill -0 "$_old_pid" 2>/dev/null; then
    pkill -TERM -P "$_old_pid" 2>/dev/null || true
    kill -TERM "$_old_pid" 2>/dev/null || true
  fi
fi
# also kill any ffmpeg left over from a missed bindr (key release not detected)
pkill -INT -x ffmpeg 2>/dev/null || true
echo "$$" > "$_PID_FILE"
trap 'rm -f "$_PID_FILE" "$tmp" "$_rc_file"' EXIT

# ---- config ----
_default_url="$(_cfg '.url')"; _default_url="${_default_url:-http://localhost:8000/v1}"
_default_model="$(_cfg '.model')"; _default_model="${_default_model:-multi}"
_default_device="$(_cfg '.device')"; _default_device="${_default_device:-default}"

STT_URL="${STT_URL:-$_default_url}"
STT_MODEL="${STT_MODEL:-$_default_model}"
[ -n "${STT_LANGUAGE:-}" ] && STT_MODEL="$STT_LANGUAGE"

# ---- i18n strings from aliases ----
_lang_name="$(_alias ".\"$STT_MODEL\".name // \"$STT_MODEL\"")"
_msg_listening="$(_alias ".\"$STT_MODEL\".listening // \"Listening…\"")"
_msg_typing="$(_alias ".\"$STT_MODEL\".typing // \"Typing…\"")"

# ---- notifications ----
_notif_id_file="/tmp/stt.notif_id"
_notif_id="$(cat "$_notif_id_file" 2>/dev/null || echo 0)"
_notify() {
  _notif_id="$(notify-send --print-id --replace-id="$_notif_id" -t 0 "stt · $_lang_name" "$1")"
  echo "$_notif_id" > "$_notif_id_file"
}
_die() { echo "$1" >&2; _notify "Error: $1"; exit 1; }

_notify "$_msg_listening"

# ---- recording setup ----
in_args=(-f pulse -i "${STT_DEVICE:-$_default_device}")
tmp="$(mktemp -t stt.XXXXXX.wav)"
_rc_file="$(mktemp -t stt.rc.XXXXXX)"

trap '' INT TERM

# ---- response parser ----
# Sets globals: accumulated, _http_status, _content_type
_parse_response() {
  local _in_headers=1
  accumulated=""
  _http_status=""
  _content_type=""

  while IFS= read -r _raw; do
    _line="${_raw%$'\r'}"
    if [ "$_in_headers" = "1" ]; then
      if [ -z "$_line" ]; then
        _in_headers=0
      elif [ -z "$_http_status" ]; then
        _tmp2="${_line#HTTP/* }"; _http_status="${_tmp2%% *}"
      elif [[ "${_line,,}" == content-type:* ]]; then
        _content_type="${_line#*: }"
      fi
      continue
    fi
    [ -z "$_line" ] && continue
    if [[ "$_content_type" == *event-stream* ]]; then
      case "$_line" in
        "data: [DONE]") break ;;
        "data: "*)
          _chunk="$(printf '%s' "${_line#data: }" | jq -r '.text // empty' 2>/dev/null || true)"
          [ -z "$_chunk" ] && continue
          accumulated+="$_chunk"
          printf '%s' "$_chunk"
          _notify "$accumulated"
          ;;
      esac
    else
      accumulated+="$_line"
    fi
  done
  # capture final line if no trailing newline (Speaches plain-text responses)
  if [ -n "$_raw" ] && [ "$_in_headers" = "0" ] && [[ "$_content_type" != *event-stream* ]]; then
    _line="${_raw%$'\r'}"
    [ -n "$_line" ] && accumulated+="$_line"
  fi
}

# ---- build VAD params from config if present ----
_vad_json="$(_cfg '.vad // empty')"
_vad_args=()
[ -n "$_vad_json" ] && _vad_args=(-F "vad_parameters=$_vad_json")

# ---- stream audio live to Speaches; tee saves for 404 fallback ----
_parse_response < <(
  { ffmpeg -loglevel error "${in_args[@]}" -ac 1 -ar 16000 -t 60 -f wav - 2>/dev/null || true; } \
    | tee "$tmp" \
    | curl -s -N -m 120 -D - -X POST "$STT_URL/audio/transcriptions" \
        -H "Authorization: Bearer cant-be-empty" \
        -H "Accept: text/event-stream" \
        -F "file=@-;filename=audio.wav;type=audio/wav" \
        -F "model=$STT_MODEL" -F "response_format=text" \
        ${STT_LANGUAGE:+-F "language=$STT_LANGUAGE"} \
        "${_vad_args[@]}" \
        2>/dev/null
  printf '%d' "$?" > "$_rc_file"
)

_notify "$_msg_typing"
trap - INT TERM

_curl_rc="$(cat "$_rc_file" 2>/dev/null || echo 1)"
[ "$_curl_rc" -eq 0 ] || _die "could not reach $STT_URL (curl exit: $_curl_rc)"

# ---- 404: model not downloaded yet — fallback to multi, download in background ----
if [ "$_http_status" = "404" ] && [ "$STT_MODEL" != "multi" ]; then
  curl -s -X POST "$STT_URL/models/$STT_MODEL" &>/dev/null &
  _fallback_name="$(_alias '.multi.name // "Multilingual"')"
  _notify "Downloading $_lang_name, using $_fallback_name…"
  _parse_response < <(
    curl -s -N -m 120 -D - -X POST "$STT_URL/audio/transcriptions" \
      -H "Authorization: Bearer cant-be-empty" \
      -H "Accept: text/event-stream" \
      -F "file=@$tmp;filename=audio.wav;type=audio/wav" \
      -F "model=multi" -F "response_format=text" \
      ${STT_LANGUAGE:+-F "language=$STT_LANGUAGE"} \
      "${_vad_args[@]}" \
      2>/dev/null
    printf '%d' "$?" > "$_rc_file"
  )
  _curl_rc="$(cat "$_rc_file" 2>/dev/null || echo 1)"
  [ "$_curl_rc" -eq 0 ] || _die "could not reach $STT_URL (curl exit: $_curl_rc)"
elif [ "$_http_status" != "200" ]; then
  _die "speaches error ($_http_status)"
fi

[ "${STT_DEBUG:-}" = "1" ] && echo "[stt] http=$_http_status ct=$_content_type raw=[${accumulated:0:120}]" >&2

text="$(printf '%s' "$accumulated" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
[ -n "$text" ] || _die "empty transcript"

printf '\n'
wl-copy -- "$text"
_notify "$text"
pw-play "$HOME/.local/share/stt/open-a-wine.mp3" &>/dev/null &
