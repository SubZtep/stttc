{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Speech-To-Text Configuration",
  "description": "The stttc models’ configuration",
  "type": "object",
  "properties": {
    "$schema": {
      "description": "A field for the JSON schema specification: https://json-schema.org/",
      "anyOf": [
        {
          "$ref": "#/$defs/Schema"
        },
        {
          "type": "null"
        }
      ]
    },
    "url": {
      "type": "string",
      "default": "http://localhost:8000/v1",
      "description": "OpenAI compatible endpoint"
    },
    "model": {
      "type": "string",
      "default": "multi",
      "description": "Default model alias (from model_aliases.json)"
    },
    "device": {
      "type": "string",
      "default": "default",
      "description": "ffmpeg/pulse input device"
    },
    "bin": {
      "type": "string",
      "default": "$HOME/.local/bin",
      "description": "User’s executable binaries"
    },
    "container": {
      "type": "string",
      "default": "speaches",
      "description": "Speaches server container name"
    },
    "vad": {
      "type": "object",
      "description": "Voice Activity Detection parameters passed to Speaches",
      "properties": {
        "threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Speech probability threshold (0.0–1.0, default 0.5). Higher = less sensitive, filters more noise."
        },
        "min_speech_duration_ms": {
          "type": "integer",
          "description": "Minimum duration of speech chunks in ms (default 250)."
        },
        "min_silence_duration_ms": {
          "type": "integer",
          "description": "Minimum silence gap between speech chunks in ms (default 2000)."
        }
      },
      "additionalProperties": false
    },
    "hypr": {
      "type": "object",
      "properties": {
        "config": {
          "type": "string",
          "default": "$HOME/.config/hypr/bindings.conf",
          "description": "Hyprland keybinds config"
        },
        "key": {
          "type": "string",
          "default": "SUPER, grave",
          "description": "Hotkey for speech recording"
        },
        "mark": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "string"
          },
          "description": "Start and end marker of updates in the config file"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "Schema": {
      "type": "string"
    }
  }
}