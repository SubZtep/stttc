{
  "$schema": "https://raw.githubusercontent.com/SubZtep/stttc/refs/tags/v0.13.0/config/schema.json",
  "url": "http://localhost:8000/v1",
  "model": "multi",
  "device": "default",
  "bin": "$HOME/.local/bin",
  "container": "speaches",
  "hypr": {
    "config": "$HOME/.config/hypr/bindings.conf",
    "key": "SUPER, grave",
    "mark": ["# >>> stttc >>>", "# <<< stttc <<<"]
  }
}
